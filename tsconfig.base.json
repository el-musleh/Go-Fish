{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "verbatimModuleSyntax": true,
    "isolatedModules": true,
    "forceConsistentCasingInFileNames": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "baseUrl": ".",
    "paths": {
      "@go-fish/contracts": ["packages/contracts/src/index.ts"],
      "@go-fish/database": ["packages/database/src/index.ts"],
      "@go-fish/ui": ["packages/ui/src/index.tsx"]
    }
  }
}
