# Copy this file to .env and fill in the values
# cp .env.example .env

# PostgreSQL connection string (matches docker-compose.yml)
DATABASE_URL=postgres://gofish:gofish@localhost:5433/gofish

# Express server port
PORT=3000

# OpenRouter API key
# Get yours at: https://openrouter.ai/settings/keys
OPENROUTER_API_KEY=

# Optional explicit model override
OPENROUTER_MODEL=google/gemini-3-flash-preview

# Resend transactional email API key
# Create one in Resend under API Keys
RESEND_API_KEY=

# Verified sender address configured in Resend
RESEND_FROM=Go Fish <noreply@gofish.ink>

# Optional fallback alias used by the app if RESEND_FROM is unset
EMAIL_FROM=Go Fish <noreply@gofish.ink>

# Real-world data APIs
TICKETMASTER_API_KEY=
OPENWEATHERMAP_API_KEY=
GOOGLE_PLACES_API_KEY=
FOURSQUARE_API_KEY=
