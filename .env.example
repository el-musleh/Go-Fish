# Copy this file to .env and fill in the values
# cp .env.example .env

# PostgreSQL connection string (matches docker-compose.yml)
DATABASE_URL=postgres://gofish:gofish@localhost:5433/gofish

# Express server port
PORT=3000

# DeepSeek API key (primary model for activity generation)
# Get yours at: https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=

# Optional: override the model (default: deepseek-chat)
DEEPSEEK_MODEL=

# OpenRouter API key (alternative if no DEEPSEEK_API_KEY)
# Get yours at: https://openrouter.ai/settings/keys
OPENROUTER_API_KEY=

# Optional explicit model override
OPENROUTER_MODEL=google/gemini-3-flash-preview

# Brevo transactional email API key
# Create one in Brevo under SMTP & API > API Keys
BREVO_API_KEY=

# Optional SMTP fallback if no BREVO_API_KEY is configured
BREVO_SMTP_HOST=smtp-relay.brevo.com
BREVO_SMTP_PORT=587
BREVO_SMTP_USER=
BREVO_SMTP_PASS=
BREVO_SMTP_SECURE=false

# Verified sender address configured in Brevo
EMAIL_FROM=Go Fish <no-reply@example.com>

# Real-world data APIs
TICKETMASTER_API_KEY=
OPENWEATHERMAP_API_KEY=
GOOGLE_PLACES_API_KEY=
FOURSQUARE_API_KEY=
