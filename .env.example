# Copy this file to .env and fill in the values
# cp .env.example .env

# PostgreSQL connection string (matches docker-compose.yml)
DATABASE_URL=postgres://gofish:gofish@localhost:5433/gofish

# Express server port
PORT=3000

# OpenRouter API key
# Get yours at: https://openrouter.ai/settings/keys
OPENROUTER_API_KEY=

# Optional explicit model override
OPENROUTER_MODEL=google/gemini-3-flash-preview

# Resend email API key
# Get yours at: https://resend.com/api-keys
RESEND_API_KEY=

# Sender address (Resend free tier requires onboarding@resend.dev)
RESEND_FROM=Go Fish <onboarding@resend.dev>

# Real-world data APIs
TICKETMASTER_API_KEY=
OPENWEATHERMAP_API_KEY=
GOOGLE_PLACES_API_KEY=
FOURSQUARE_API_KEY=
