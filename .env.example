# Copy this file to .env and fill in the values
# cp .env.example .env

# ── Database ────────────────────────────────────────────────────────────────
# Local dev (matches docker-compose.yml). Railway sets this automatically.
DATABASE_URL=postgres://gofish:gofish@localhost:5433/gofish

# Connection pool tuning (optional — safe defaults shown)
# DB_POOL_MAX=10                  # max simultaneous connections per process
# DB_IDLE_TIMEOUT_MS=10000        # close idle connections after N ms
# DB_CONNECTION_TIMEOUT_MS=5000   # fail fast if pool is exhausted (0 = wait forever)
# DB_SSL=false                    # set to true for managed databases (Railway, Supabase)

# ── Server ──────────────────────────────────────────────────────────────────
PORT=3000

# ── AI ──────────────────────────────────────────────────────────────────────
# DeepSeek (primary model for activity generation)
# Get yours at: https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=
# Optional: override the model (default: deepseek-chat)
DEEPSEEK_MODEL=

# OpenRouter (alternative if no DEEPSEEK_API_KEY)
# Get yours at: https://openrouter.ai/settings/keys
OPENROUTER_API_KEY=
# Optional explicit model override
OPENROUTER_MODEL=google/gemini-3-flash-preview

# Google / Gemini (alternative)
GOOGLE_API_KEY=
GEMINI_API_KEY=
GOOGLE_MODEL=

# ── Email ────────────────────────────────────────────────────────────────────
# Verified sender address
EMAIL_FROM=Go Fish <noreply@gofish.ink>

# Resend transactional email
# Get key at https://resend.com/api-keys
RESEND_API_KEY=
RESEND_FROM=Go Fish <noreply@gofish.ink>

# Brevo transactional email (alternative to Resend)
# Create one in Brevo under SMTP & API > API Keys
BREVO_API_KEY=
BREVO_FROM=

# Optional Brevo SMTP fallback
BREVO_SMTP_HOST=smtp-relay.brevo.com
BREVO_SMTP_PORT=587
BREVO_SMTP_USER=
BREVO_SMTP_PASS=
BREVO_SMTP_SECURE=false

# ── Real-world data APIs ─────────────────────────────────────────────────────
TICKETMASTER_API_KEY=
OPENWEATHERMAP_API_KEY=
GOOGLE_PLACES_API_KEY=
FOURSQUARE_API_KEY=

# ── Backend / Supabase ───────────────────────────────────────────────────────
# Used by the backend to verify Supabase JWTs on every API request.
# Find these in your Supabase project: Settings > API
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# ── Frontend / Supabase ──────────────────────────────────────────────────────
# Must also be set in Railway dashboard — baked into the frontend at build time
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
VITE_APP_VERSION=1.6.0
