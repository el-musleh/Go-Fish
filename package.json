{
  "name": "go-fish-backend",
  "version": "1.6.0",
  "description": "Go Fish - Group activity finder backend",
  "main": "dist/index.js",
  "scripts": {
    "build": "node node_modules/typescript/bin/tsc",
    "build:all": "npm run build && npm --prefix client run build",
    "start": "NODE_ENV=production node dist/index.js",
    "dev": "node node_modules/ts-node/dist/bin.js src/index.ts",
    "test": "node node_modules/vitest/vitest.mjs --run",
    "prepare": "node node_modules/husky/bin.js 2>/dev/null || true"
  },
  "dependencies": {
    "@langchain/langgraph": "^1.2.6",
    "@langchain/openrouter": "^0.1.8",
    "@supabase/supabase-js": "^2.100.1",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.1",
    "langchain": "^1.2.37",
    "pg": "^8.20.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^25.5.0",
    "@types/pg": "^8.20.0",
    "@types/supertest": "^7.2.0",
    "fast-check": "^4.6.0",
    "husky": "^9.1.7",
    "supertest": "^7.2.2",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  }
}
