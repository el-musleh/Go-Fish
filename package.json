{
  "name": "go-fish-backend",
  "version": "1.6.0",
  "description": "Go Fish - Group activity finder backend",
  "main": "dist/index.js",
  "scripts": {
    "build": "node node_modules/typescript/bin/tsc",
    "build:all": "npm run build && npm --prefix client run build",
    "start": "NODE_ENV=production node dist/index.js",
    "dev": "node node_modules/ts-node/dist/bin.js src/index.ts",
    "test": "node node_modules/vitest/vitest.mjs --run",
    "test:watch": "node node_modules/vitest/vitest.mjs",
    "prepare": "node node_modules/husky/bin.js 2>/dev/null || true",
    "licenses": "node scripts/generate-licenses.js && cp public/licenses.json client/public/licenses.json"
  },
  "dependencies": {
    "@langchain/langgraph": "^1.2.7",
    "@langchain/openrouter": "^0.2.0",
    "@supabase/supabase-js": "^2.101.1",
    "dotenv": "^17.4.1",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.2",
    "jose": "^6.2.2",
    "jsonwebtoken": "^9.0.3",
    "langchain": "^1.3.0",
    "pg": "^8.20.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20.11.0",
    "@types/pg": "^8.20.0",
    "@types/supertest": "^7.2.0",
    "fast-check": "^3.15.0",
    "husky": "^9.1.7",
    "supertest": "^7.2.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3",
    "vitest": "^2.1.0"
  }
}
