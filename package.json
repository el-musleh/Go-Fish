{
  "name": "go-fish",
  "private": true,
  "packageManager": "pnpm@10.32.1",
  "scripts": {
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "dev:web": "pnpm --filter @go-fish/web dev",
    "dev:api": "pnpm --filter @go-fish/api dev",
    "dev:worker": "pnpm --filter @go-fish/worker dev",
    "db:generate": "pnpm --filter @go-fish/database db:generate",
    "db:push": "pnpm --filter @go-fish/database db:push",
    "postinstall": "pnpm db:generate"
  }
}

